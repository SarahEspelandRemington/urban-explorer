# ─── Required secrets ────────────────────────────────────────────────────────
#
# Add these in Replit's Secrets tab (the padlock icon in the sidebar).
# DATABASE_URL and PGHOST/PGPORT/PGDATABASE/PGUSER/PGPASSWORD are automatically
# provisioned by the PostgreSQL module — do not set them manually.
# REPLIT_DOMAINS, REPLIT_DEV_DOMAIN, and REPL_ID are injected at runtime.

# Express session cookie signing key.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=

# OpenAI / AI Integrations — set automatically when you connect the
# "OpenAI" integration via the Integrations tab in Replit.
# Do NOT set these by hand; they rotate and are managed by Replit.
AI_INTEGRATIONS_OPENAI_BASE_URL=
AI_INTEGRATIONS_OPENAI_API_KEY=

# ─── Optional tuning (Replit Secrets tab or environment) ────────────────────
# All values below are parsed and validated at startup by artifacts/api-server/src/config.ts.
# Invalid values log a warning and fall back to the listed default automatically.

# Maximum number of audio rows to keep in the database.
# Each row is roughly 30–200 KB of base64-encoded MP3, so 100 rows ≈ 5–20 MB.
# Must be a positive integer; default: 100.
AUDIO_DB_MAX_ENTRIES=100

# Maximum age in days for cached place photos stored in the database.
# Rows older than this cutoff are deleted by the hourly cleanup job.
# Must be a positive number; default: 7.
PHOTO_CACHE_MAX_AGE_DAYS=7

# Walk Mode heading-bias tuning. These three values control how the server
# scores candidate places during Walk Mode navigation. They take effect
# immediately on server restart without a mobile rebuild.
# All must be finite numbers; defaults shown below.
WALK_FORWARD_BIAS_METERS=200
WALK_OFF_AXIS_PENALTY_DEG=70
WALK_OFF_AXIS_PENALTY_METERS=120

# OpenID Connect issuer URL for Replit Auth.
# Must be a valid URL; default: https://replit.com/oidc.
# ISSUER_URL=https://replit.com/oidc

# ─── Optional secrets (Replit Secrets tab) ───────────────────────────────────

# Sentry crash reporting DSN for the mobile app.
# Find it at: sentry.io → Settings → Projects → <project> → Client Keys (DSN)
# Leave blank to disable crash reporting (the app runs fine without it).
EXPO_PUBLIC_SENTRY_DSN=

# ─── EAS build secrets (NOT Replit secrets) ───────────────────────────────────
# These are only needed during `eas build` to upload source maps to Sentry.
# They are irrelevant for local Expo development.
# Set them on EAS (not here) with: eas secret:create --name <KEY> --value <VALUE>
#
# SENTRY_AUTH_TOKEN  — internal integration token from sentry.io
#                      (Settings → Developer Settings → Internal Integrations,
#                       needs project:releases + org:read scopes)
# SENTRY_ORG         — your Sentry organisation slug (visible in the URL)
# SENTRY_PROJECT     — your Sentry project slug
