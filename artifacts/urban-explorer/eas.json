{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://urban-explorer-ihsy.onrender.com",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true",
        "SENTRY_CLI_EXECUTABLE": "/usr/bin/true"
      }
    },
    "development-simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://urban-explorer-ihsy.onrender.com",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true",
        "SENTRY_CLI_EXECUTABLE": "/usr/bin/true"
      }
    },
    "preview": {
      "distribution": "internal",
      "autoIncrement": true,
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://urban-explorer-ihsy.onrender.com",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true",
        "SENTRY_CLI_EXECUTABLE": "/usr/bin/true"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://urban-explorer-ihsy.onrender.com",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true",
        "SENTRY_CLI_EXECUTABLE": "/usr/bin/true"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
