modules = ["nodejs-24", "postgresql-16", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "privacy-tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/urban-explorer run test"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "lint-rules"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run lint:rules"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "lint"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run lint"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run typecheck"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "conflict-markers"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run check:conflicts"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "spec-sync"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run spec-sync"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "format"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run format:check"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "ci"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run ci"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "codegen-sync"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run codegen:check"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "artifacts/urban-explorer: expo"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "artifacts/urban-explorer"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/urban-explorer run dev"
cwd = "./artifacts/urban-explorer"
waitForPort = 23584
ensurePreviewReachable = "/status"
router = "expo-domain"

[workflows.workflow.tasks.env]
PORT = "23584"
BASE_PATH = "/"

[[workflows.workflow]]
name = "artifacts/api-server: API Server"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "3B4_FFSkEVBkAeYMFRJ2e"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run dev"
cwd = "./artifacts/api-server"
waitForPort = 8080

[workflows.workflow.tasks.env]
PORT = "8080"

[[workflows.workflow]]
name = "artifacts/mockup-sandbox: Component Preview Server"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "XegfDyZt7HqfW2Bb8Ghoy"
isCanvasWorkflow = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/mockup-sandbox run dev"
cwd = "./artifacts/mockup-sandbox"
waitForPort = 8081

[workflows.workflow.tasks.env]
PORT = "8081"
BASE_PATH = "/__mockup"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 4200

[[ports]]
localPort = 8083
externalPort = 3002

[[ports]]
localPort = 8084
externalPort = 5000

[[ports]]
localPort = 8085
externalPort = 3001

[[ports]]
localPort = 23584
externalPort = 3000

[[ports]]
localPort = 23585
externalPort = 3003

[nix]
channel = "stable-25_05"
